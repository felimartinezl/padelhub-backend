{
  "openapi": "3.0.0",
  "info": {
    "title": "PadelHub API - Sistema de Gestión de Partidos",
    "version": "1.2.0",
    "description": "Documentación técnica oficial del backend PadelHub."
  },
  "servers": [
    {
      "url": "https://padelhub-backend-phi.vercel.app/api",
      "description": "Servidor de producción en Vercel"
    }
  ],
  "tags": [
    { "name": "1. Autenticación", "description": "Login y recuperación de contraseña" },
    { "name": "2. Usuarios", "description": "Registro, consulta y eliminación de jugadores" },
    { "name": "3. Perfil", "description": "Perfil deportivo, edición y foto" },
    { "name": "4. Partidos", "description": "Creación y consulta de partidos" },
    { "name": "5. Invitaciones", "description": "Invitar jugadores y responder invitaciones" }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["1. Autenticación"],
        "summary": "Iniciar sesión",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["rut", "password"],
                "properties": {
                  "rut":      { "type": "integer", "example": 12345678 },
                  "password": { "type": "string",  "example": "clave123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login exitoso. Devuelve datos del usuario." },
          "400": { "description": "RUT o contraseña faltantes." },
          "401": { "description": "Credenciales incorrectas." }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["1. Autenticación"],
        "summary": "Solicitar código de recuperación por SMS",
        "description": "Genera un código OTP de 6 dígitos con vigencia de 10 minutos y lo envía por SMS al número asociado al RUT.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["rut"],
                "properties": {
                  "rut": { "type": "integer", "example": 12345678 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Si el RUT existe, se envía el SMS. Respuesta genérica por seguridad." },
          "400": { "description": "RUT faltante." },
          "500": { "description": "Error al enviar el SMS." }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": ["1. Autenticación"],
        "summary": "Restablecer contraseña con código OTP",
        "description": "Verifica el código recibido por SMS y actualiza la contraseña. El código se invalida al usarse.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["rut", "code", "new_password"],
                "properties": {
                  "rut":          { "type": "integer", "example": 12345678 },
                  "code":         { "type": "string",  "example": "483920" },
                  "new_password": { "type": "string",  "example": "nuevaClave456", "minLength": 6 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Contraseña actualizada correctamente." },
          "400": { "description": "Campos faltantes, contraseña muy corta, o código inválido/expirado." }
        }
      }
    },
    "/users": {
      "post": {
        "tags": ["2. Usuarios"],
        "summary": "Registrar nuevo jugador",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["rut", "dv_rut", "phone", "name", "password", "zone"],
                "properties": {
                  "rut":      { "type": "integer", "example": 12345678 },
                  "dv_rut":   { "type": "string",  "example": "5" },
                  "phone":    { "type": "string",  "example": "+56912345678" },
                  "name":     { "type": "string",  "example": "Felipe Martínez" },
                  "password": { "type": "string",  "example": "clave123" },
                  "zone":     { "type": "string",  "example": "Concepción" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuario creado exitosamente." },
          "400": { "description": "Campos requeridos faltantes." },
          "409": { "description": "RUT o teléfono ya registrado." }
        }
      },
      "get": {
        "tags": ["2. Usuarios"],
        "summary": "Obtener todos los jugadores",
        "responses": {
          "200": { "description": "Lista completa de jugadores ordenada por fecha de registro." }
        }
      },
      "delete": {
        "tags": ["2. Usuarios"],
        "summary": "Eliminar usuario por RUT",
        "parameters": [
          { "name": "rut", "in": "query", "required": true, "schema": { "type": "integer", "example": 12345678 } }
        ],
        "responses": {
          "200": { "description": "Usuario eliminado correctamente." },
          "404": { "description": "Usuario no encontrado." }
        }
      }
    },
    "/users/search-rut": {
      "get": {
        "tags": ["2. Usuarios"],
        "summary": "Buscar jugador por RUT (query param)",
        "parameters": [
          { "name": "rut", "in": "query", "required": true, "schema": { "type": "integer", "example": 12345678 } }
        ],
        "responses": {
          "200": { "description": "Jugador encontrado." },
          "404": { "description": "Jugador no encontrado." }
        }
      }
    },
    "/users/{rut}/profile": {
      "get": {
        "tags": ["3. Perfil"],
        "summary": "Ver perfil y estadísticas",
        "parameters": [
          { "name": "rut", "in": "path", "required": true, "schema": { "type": "integer", "example": 12345678 } }
        ],
        "responses": {
          "200": { "description": "Perfil del jugador con estadísticas de partidos." },
          "404": { "description": "Jugador no encontrado." }
        }
      },
      "patch": {
        "tags": ["3. Perfil"],
        "summary": "Editar perfil del jugador",
        "description": "Actualiza uno o más campos del perfil. Todos los campos son opcionales pero se requiere al menos uno.",
        "parameters": [
          { "name": "rut", "in": "path", "required": true, "schema": { "type": "integer", "example": 12345678 } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name":  { "type": "string", "example": "Felipe Martínez" },
                  "phone": { "type": "string", "example": "+56987654321" },
                  "zone":  { "type": "string", "example": "Santiago" },
                  "level": {
                    "type": "string",
                    "enum": ["primera", "segunda", "tercera", "cuarta", "quinta", "sexta", "septima_mas"],
                    "example": "segunda"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Perfil actualizado correctamente." },
          "400": { "description": "Sin campos para actualizar o nivel inválido." },
          "404": { "description": "Jugador no encontrado." },
          "409": { "description": "El teléfono ya está en uso por otro usuario." }
        }
      }
    },
    "/users/{rut}/profile/photo": {
      "post": {
        "tags": ["3. Perfil"],
        "summary": "Subir o cambiar foto de perfil",
        "parameters": [
          { "name": "rut", "in": "path", "required": true, "schema": { "type": "string", "example": "12345678" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Foto guardada en Cloudinary." }
        }
      },
      "delete": {
        "tags": ["3. Perfil"],
        "summary": "Eliminar foto de perfil",
        "parameters": [
          { "name": "rut", "in": "path", "required": true, "schema": { "type": "string", "example": "12345678" } }
        ],
        "responses": {
          "200": { "description": "Foto eliminada de Cloudinary y BD." }
        }
      }
    },
    "/matches": {
      "post": {
        "tags": ["4. Partidos"],
        "summary": "Crear partido",
        "description": "Crea un partido y agrega automáticamente al organizador como primer jugador confirmado en team_a.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["organizer_id", "club", "match_date", "match_time"],
                "properties": {
                  "organizer_id": { "type": "string", "format": "uuid", "example": "9e094ce9-64a6-44de-7806-744cdbb02695" },
                  "club":         { "type": "string", "example": "Padel Break Club" },
                  "format":       { "type": "string", "enum": ["singles", "doubles"], "example": "doubles", "default": "doubles" },
                  "match_date":   { "type": "string", "format": "date", "example": "2026-05-25" },
                  "match_time":   { "type": "string", "example": "19:30:00" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Partido creado. El organizador queda agregado como jugador." },
          "400": { "description": "Campos requeridos faltantes." }
        }
      },
      "get": {
        "tags": ["4. Partidos"],
        "summary": "Listar partidos abiertos",
        "description": "Retorna partidos filtrados por zona del organizador. Incluye jugadores confirmados, cupos disponibles e indicador de partido lleno.",
        "parameters": [
          {
            "name": "zone",
            "in": "query",
            "required": false,
            "description": "Filtra partidos por la zona del organizador (ej: Concepción)",
            "schema": { "type": "string", "example": "Concepción" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Estado del partido. Por defecto: open",
            "schema": { "type": "string", "enum": ["open", "confirmed", "in_progress", "finished", "cancelled"], "default": "open" }
          }
        ],
        "responses": {
          "200": { "description": "Lista de partidos con jugadores, cupos y zona." }
        }
      }
    },
    "/matches/{id}/invite": {
      "post": {
        "tags": ["5. Invitaciones"],
        "summary": "Enviar invitación a un jugador",
        "description": "Cualquier jugador del partido puede invitar a otro usuario. No se puede invitar si el partido está lleno o no está 'open'.",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "UUID del partido", "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["invited_by", "user_id"],
                "properties": {
                  "invited_by": { "type": "string", "format": "uuid", "description": "UUID del jugador que envía la invitación" },
                  "user_id":    { "type": "string", "format": "uuid", "description": "UUID del jugador invitado" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Invitación enviada correctamente." },
          "400": { "description": "Partido no disponible, completo, o auto-invitación." },
          "403": { "description": "El remitente no es jugador del partido." },
          "404": { "description": "Partido o jugador no encontrado." },
          "409": { "description": "Ya existe una invitación pendiente para este jugador." }
        }
      }
    },
    "/matches/{id}/invitations": {
      "get": {
        "tags": ["5. Invitaciones"],
        "summary": "Ver invitaciones enviadas de un partido",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "UUID del partido", "schema": { "type": "string", "format": "uuid" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string", "enum": ["pending", "accepted", "declined"] } }
        ],
        "responses": {
          "200": { "description": "Lista de invitaciones con datos del invitado e invitador." },
          "404": { "description": "Partido no encontrado." }
        }
      }
    },
    "/matches/{id}/join": {
      "post": {
        "tags": ["4. Partidos"],
        "summary": "Unirse a un partido",
        "description": "Agrega al jugador al partido. Si el partido queda completo, cambia su estado a 'confirmed'. El equipo se asigna automáticamente.",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "UUID del partido", "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id"],
                "properties": {
                  "user_id": { "type": "string", "format": "uuid", "example": "9e094ce9-64a6-44de-7806-744cdbb02695" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Jugador agregado al partido correctamente." },
          "400": { "description": "Partido no disponible o ya está completo." },
          "404": { "description": "Partido no encontrado." },
          "409": { "description": "El jugador ya es parte de este partido." }
        }
      },
      "delete": {
        "tags": ["4. Partidos"],
        "summary": "Salir de un partido",
        "description": "Elimina al jugador del partido. Si el partido estaba completo, vuelve a estado 'open'. El organizador no puede abandonar.",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "UUID del partido", "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id"],
                "properties": {
                  "user_id": { "type": "string", "format": "uuid", "example": "9e094ce9-64a6-44de-7806-744cdbb02695" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Jugador eliminado del partido." },
          "400": { "description": "El organizador no puede abandonar el partido." },
          "404": { "description": "Partido no encontrado o jugador no es parte del partido." }
        }
      }
    },
    "/users/{rut}/invitations": {
      "get": {
        "tags": ["5. Invitaciones"],
        "summary": "Ver invitaciones recibidas por un jugador",
        "description": "Devuelve las invitaciones del jugador. Por defecto solo las pendientes. Usar ?status=all para ver todas.",
        "parameters": [
          { "name": "rut", "in": "path", "required": true, "description": "RUT o UUID del jugador", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string", "enum": ["pending", "accepted", "declined", "all"], "default": "pending" } }
        ],
        "responses": {
          "200": { "description": "Lista de invitaciones con datos del partido e invitador." },
          "404": { "description": "Jugador no encontrado." }
        }
      }
    },
    "/invitations/{id}": {
      "patch": {
        "tags": ["5. Invitaciones"],
        "summary": "Aceptar o rechazar una invitación",
        "description": "Solo el jugador invitado puede responder. Si acepta, queda unido automáticamente al partido.",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "UUID de la invitación", "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id", "status"],
                "properties": {
                  "user_id": { "type": "string", "format": "uuid", "description": "UUID del jugador que responde (debe ser el invitado)" },
                  "status":  { "type": "string", "enum": ["accepted", "declined"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Invitación respondida. Si aceptó, queda unido al partido." },
          "400": { "description": "Invitación ya respondida, partido no disponible o lleno." },
          "403": { "description": "No tienes permiso para responder esta invitación." },
          "404": { "description": "Invitación no encontrada." }
        }
      }
    }
  }
}
