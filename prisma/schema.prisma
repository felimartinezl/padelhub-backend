generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model match_players {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  match_id              String        @db.Uuid
  user_id               String        @db.Uuid
  team                  team_side     @default(team_a)
  status                player_status @default(pending)
  joined_at             DateTime      @default(now()) @db.Timestamp(6)
  confirmed_presence    Boolean       @default(false)
  presence_confirmed_at DateTime?     @db.Timestamp(6)
  matches               matches       @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                 users         @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@unique([match_id, user_id], map: "uq_match_player")
  @@index([match_id], map: "idx_match_players_match")
  @@index([status], map: "idx_match_players_status")
  @@index([user_id], map: "idx_match_players_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model match_results {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  match_id      String      @unique @db.Uuid
  registered_by String      @db.Uuid
  score_team_a  String      @db.VarChar(20)
  score_team_b  String      @db.VarChar(20)
  winner        winner_team
  registered_at DateTime    @default(now()) @db.Timestamp(6)
  confirmed     Boolean     @default(false)
  confirmed_by  String?     @db.Uuid
  confirmed_at  DateTime?   @db.Timestamp(6)
  matches       matches     @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users       @relation(fields: [registered_by], references: [id], onUpdate: NoAction)

  @@index([match_id], map: "idx_match_results_match")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model matches {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizer_id  String          @db.Uuid
  club          String          @db.VarChar(200)
  format        match_format    @default(doubles)
  status        match_status    @default(open)
  match_date    DateTime        @db.Date
  match_time    DateTime        @db.Time(6)
  created_at    DateTime        @default(now()) @db.Timestamp(6)
  updated_at    DateTime        @default(now()) @db.Timestamp(6)
  match_players     match_players[]
  match_results     match_results?
  users             users              @relation(fields: [organizer_id], references: [id], onUpdate: NoAction)
  mmr_history       mmr_history[]
  match_invitations match_invitations[]

  @@index([match_date], map: "idx_matches_date")
  @@index([organizer_id], map: "idx_matches_organizer")
  @@index([status], map: "idx_matches_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model mmr_history {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  match_id      String   @db.Uuid
  mmr_before    Int
  mmr_after     Int
  delta         Int      @default(dbgenerated("(mmr_after - mmr_before)"))
  calculated_at DateTime @default(now()) @db.Timestamp(6)
  matches       matches  @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, match_id], map: "uq_mmr_per_match_user")
  @@index([match_id], map: "idx_mmr_history_match")
  @@index([user_id, calculated_at(sort: Desc)], map: "idx_mmr_history_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refresh_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique @db.VarChar(512)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_refresh_tokens_exp")
  @@index([user_id], map: "idx_refresh_tokens_user")
}

model password_reset_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  code       String   @db.VarChar(6)
  expires_at DateTime @db.Timestamp(6)
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_reset_tokens_user")
  @@index([expires_at], map: "idx_reset_tokens_exp")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rut            Int
  dv_rut         String           @db.Char(1)
  phone          String           @unique @db.VarChar(20)
  name           String           @db.VarChar(100)
  password_hash  String           @db.VarChar(255)
  photo_url      String?          @db.VarChar(500)
  level          user_level       @default(tercera)
  zone           String           @db.VarChar(100)
  mmr            Int              @default(1000)
  role           user_role        @default(player)
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now()) @db.Timestamp(6)
  updated_at     DateTime         @default(now()) @db.Timestamp(6)
  match_players        match_players[]
  match_results        match_results[]
  matches              matches[]
  mmr_history          mmr_history[]
  refresh_tokens       refresh_tokens[]
  password_reset_tokens password_reset_tokens[]
  invitations_sent     match_invitations[] @relation("invitations_sent")
  invitations_received match_invitations[] @relation("invitations_received")
  device_tokens        device_tokens[]

  @@unique([rut, dv_rut], map: "uq_rut")
  @@index([is_active], map: "idx_users_active")
  @@index([level], map: "idx_users_level")
  @@index([mmr(sort: Desc)], map: "idx_users_mmr")
  @@index([rut], map: "idx_users_rut")
  @@index([zone], map: "idx_users_zone")
}

model device_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique @db.VarChar(500)
  platform   String   @db.VarChar(10)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_device_tokens_user")
}

model courts {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String            @db.VarChar(100)
  address         String            @db.VarChar(200)
  zone            String            @db.VarChar(100)
  surface         court_surface     @default(indoor)
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  updated_at      DateTime          @default(now()) @db.Timestamp(6)
  court_schedules court_schedules[]

  @@index([zone], map: "idx_courts_zone")
  @@index([is_active], map: "idx_courts_active")
}

model court_schedules {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  court_id     String   @db.Uuid
  day_of_week  Int
  open_time    DateTime @db.Time(6)
  close_time   DateTime @db.Time(6)
  is_available Boolean  @default(true)
  courts       courts   @relation(fields: [court_id], references: [id], onDelete: Cascade)

  @@unique([court_id, day_of_week], map: "uq_court_schedule")
  @@index([court_id], map: "idx_schedules_court")
}

model match_invitations {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  match_id     String            @db.Uuid
  invited_by   String            @db.Uuid
  user_id      String            @db.Uuid
  status       invitation_status @default(pending)
  created_at   DateTime          @default(now()) @db.Timestamp(6)
  responded_at DateTime?         @db.Timestamp(6)
  matches      matches           @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inviter      users             @relation("invitations_sent", fields: [invited_by], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invitee      users             @relation("invitations_received", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([match_id, user_id], map: "uq_match_invitation")
  @@index([match_id], map: "idx_invitations_match")
  @@index([user_id], map: "idx_invitations_user")
  @@index([status], map: "idx_invitations_status")
}

enum court_surface {
  indoor
  outdoor
  covered
}

enum match_format {
  doubles
  singles
}

enum match_status {
  open
  confirmed
  in_progress
  finished
  cancelled
}

enum player_status {
  pending
  confirmed
  rejected
  removed
}

enum team_side {
  team_a
  team_b
}

enum user_level {
  primera  @map("1ra")
  segunda  @map("2da")
  tercera  @map("3ra")
  cuarta  @map("4ta")
  quinta  @map("5ta")
  sexta  @map("6ta")
  septima_mas @map("7ma+")
}

enum user_role {
  player
  admin
}

enum winner_team {
  team_a
  team_b
  draw
}

enum invitation_status {
  pending
  accepted
  declined
}
